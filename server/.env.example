# ─── Zorunlu ─────────────────────────────────────────
# MySQL / MariaDB bağlantı URL'i (Prisma adapter ile uyumlu)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# JWT imzalama (güçlü rastgele string)
JWT_SECRET="degistir-uzun-rastgele-bir-deger"

# ─── Canlı yayın (mutlaka doldur) ─────────────────────
# API'nin tarayıcıdan erişilen kök adresi — path YOK, sonda / YOK
# Örnek: https://api.senindomainin.com
# Görsel yükleyince dönen URL buna göre üretilir; boş bırakılırsa localhost kalır.
SERVER_URL="http://localhost:4000"

# İzin verilen frontend adresleri (virgülle ayır)
# Örnek: https://senindomainin.com,https://www.senindomainin.com
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── Opsiyonel ───────────────────────────────────────
PORT=4000
NODE_ENV=development

# Yüklenen görsellerin diske yazılacağı klasör (Docker volume vb.)
# UPLOADS_DIR=/data/uploads

# Nginx / Traefik arkasında doğru istemci IP'si için
# TRUST_PROXY=1

# ─── İletişim formu (/api/contact) ───────────────────
# Tanımlı değilse iletişim endpoint'i yapılandırılmamış hatası verir
# CONTACT_TO_EMAIL=fatihbilig@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=fatihbilig@gmail.com
# SMTP_PASS=uygulamasifresi16karakter
